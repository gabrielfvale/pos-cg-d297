  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::PaperCave.AnimationFrameView3D
  frames:
  - label: 1. Request
    description: Game app sends modelID, confidence threshold, and target emotion
      (e.g. 'happiness') to RAG App.
    image: {fileID: 0}
  - label: 2. Retrieve
    description: "RAG App queries Redis for the character's blend shape\u2013AU map,
      filtered by confidence score."
    image: {fileID: 0}
  - label: 3. Generate
    description: "LLM Animator receives the filtered map + emotion and produces a
      JSON animation timeline with keyframes (0\u2013100 activation)."
    image: {fileID: 0}
  - label: 4. Apply
    description: Game runtime receives the JSON and drives blend shape weights on
      the 3D character in real time.
    image: {fileID: 0}
