# Paper Cave — Variáveis de Ambiente
# Copie este arquivo para .env e preencha as chaves necessárias.
# Apenas .env é lido pelo sistema. .env.example é só referência.
# NUNCA commite o arquivo .env.

# Google Gemini
GEMINI_API_KEY=sua_chave_aqui

# OpenAI (necessário se provider=openai ou provider=openai_compatible)
# OPENAI_API_KEY=sua_chave_aqui

# Anthropic Claude (necessário se provider=anthropic)
# ANTHROPIC_API_KEY=sua_chave_aqui

# LMStudio e Ollama não precisam de chave de API
