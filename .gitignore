# Unity project gitignore
#
# Keep the files needed to open the project in Unity:
# Assets, Packages, ProjectSettings and their .meta files.
# Ignore generated caches, local editor state, builds and IDE files.

# Unity generated folders. These rules cover both a Unity project at the
# repository root and a nested project such as "My project/".
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/
.utmp/

# Unity generated/cache files inside Assets.
[Aa]ssets/[Ss]ceneDependencyCache*
[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
[Aa]ssets/StreamingAssets/aa*
[Aa]ssets/AddressableAssetsData/link.xml*
[Aa]ssets/AddressableAssetsData/*/*.bin*
[Aa]ssets/Addressables_Temp*
[Aa]ssets/Plugins/Editor/JetBrains*
[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers/
[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta
ServerData/

# Nested Unity project paths kept for compatibility with the previous layout.
My project/[Ll]ibrary/
My project/[Tt]emp/
My project/[Oo]bj/
My project/[Bb]uild/
My project/[Bb]uilds/
My project/[Ll]ogs/
My project/[Uu]ser[Ss]ettings/
My project/[Mm]emoryCaptures/
My project/[Rr]ecordings/
My project/.utmp/
My project/[Aa]ssets/[Ss]ceneDependencyCache*
My project/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
My project/[Aa]ssets/StreamingAssets/aa*
My project/[Aa]ssets/AddressableAssetsData/link.xml*
My project/[Aa]ssets/AddressableAssetsData/*/*.bin*
My project/[Aa]ssets/Addressables_Temp*
My project/[Aa]ssets/Plugins/Editor/JetBrains*
My project/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
My project/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
My project/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers/
My project/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta
My project/ServerData/

# Build artifacts and exports.
*.apk
*.aab
*.app
*.unitypackage
*.unitypackage.meta
ExportedObj/

# Blender backups.
*.blend1
*.blend1.meta

# IDE/editor generated files.
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash reports.
sysinfo.txt
mono_crash.*
crashlytics-build.properties

# OS files.
.DS_Store
Thumbs.db
