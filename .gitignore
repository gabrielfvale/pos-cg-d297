# ================================================================
# .gitignore — repositório híbrido
#   Unity (raiz = projeto Unity)  +  Python (PaperCave/)
# ================================================================


# ----------------------------------------------------------------
# UNITY  (raiz do repositório = raiz do projeto Unity)
# ----------------------------------------------------------------

# Pastas geradas — nunca versionar (Library chega a ~2 GB)
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/
.utmp/

# Caches de Assets gerados pelo Unity
[Aa]ssets/[Ss]ceneDependencyCache*
[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
[Aa]ssets/StreamingAssets/aa*
[Aa]ssets/AddressableAssetsData/link.xml*
[Aa]ssets/AddressableAssetsData/*/*.bin*
[Aa]ssets/Addressables_Temp*
[Aa]ssets/Plugins/Editor/JetBrains*
[Aa]ssets/Unity.VisualScripting.Generated/

# PaperCaveData — gerado pelo python unity_export.py, não versionar
# (imagens e manifests são recriados pelo pipeline antes de abrir o Unity)
[Aa]ssets/PaperCaveData/*/images/
[Aa]ssets/PaperCaveData/*/*.json
[Aa]ssets/PaperCaveData/*/*.json.meta

/ServerData/

# Blender backups
*.blend1
*.blend1.meta

# Builds e pacotes
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
ExportedObj/

# Projetos/soluções gerados por IDEs
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash / Mono
sysinfo.txt
mono_crash.*
crashlytics-build.properties

# TestRunner
InitTestScene*.unity*


# ----------------------------------------------------------------
# PYTHON / PaperCave/
# (PaperCave/.gitignore continua valendo dentro da pasta)
# ----------------------------------------------------------------

# PDFs de entrada (pesados — distribuir fora do git)
PaperCave/papers/*.pdf

# Imagens extraídas dentro das subpastas de papers (FIG_*.png etc.)
# Ficam em Assets/PaperCaveData/ após o unity_export.py
PaperCave/papers/*/

# Outputs e logs gerados em execução
PaperCave/outputs/
PaperCave/logs/

# Configuração local com chaves/segredos
PaperCave/.env
PaperCave/config/config.yaml

# Ambientes virtuais e caches Python
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
dist/
*.db
*.sqlite3


# ----------------------------------------------------------------
# EDITORES / IDEs / OS
# ----------------------------------------------------------------
.vs/
.vscode/
.idea/
.gradle/
.consulo/
.claude/
*.DotSettings.user
*.swp
*.log
.DS_Store
Thumbs.db
desktop.ini
